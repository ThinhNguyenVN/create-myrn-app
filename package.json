{
  "name": "create-myrn-app",
  "version": "0.1.0",
  "description": "Bootstrap a React Native project from the MyRN template.",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "create-myrn-app": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/cli.ts --format esm --target node18 --clean --out-dir dist",
    "dev": "tsup src/cli.ts --format esm --target node18 --watch --out-dir dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "keywords": [
    "cli",
    "expo",
    "react-native",
    "scaffold",
    "template"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThinhNguyenVN/create-myrn-app.git"
  },
  "bugs": {
    "url": "https://github.com/ThinhNguyenVN/create-myrn-app/issues"
  },
  "homepage": "https://github.com/ThinhNguyenVN/create-myrn-app#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "degit": "^2.8.4",
    "execa": "^9.6.1",
    "validate-npm-package-name": "^7.0.2"
  },
  "devDependencies": {
    "@types/degit": "^2.8.6",
    "@types/node": "^25.6.0",
    "@types/validate-npm-package-name": "^4.0.2",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
